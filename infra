#!/bin/bash

# ═══════════════════════════════════════════════════════════════════════════
# Infrastructure Management System v2.0 - Main Orchestrator
# ═══════════════════════════════════════════════════════════════════════════
# Purpose: Primary entry point and operation coordination
# Author: Infrastructure Management System v2.0
# Last Updated: May 28, 2024

set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Script Setup and Module Loading
# ─────────────────────────────────────────────────────────────────────────────

# Initialize environment variables first
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
export SCRIPT_DIR
export PROJECT_ROOT

# Source logger first to make debug_message available
source "$(dirname "$0")/logger.sh"

# Enable debug output if needed for initial loading
DEBUG_LEVEL=${DEBUG_LEVEL:-0}

# Source required modules in dependency order
source "$(dirname "$0")/output.sh"
source "$(dirname "$0")/shared.sh"

# Now debug_message is available
debug_message "Loading modules..."

source "$(dirname "$0")/environment.sh"
source "$(dirname "$0")/modules.sh"
source "$(dirname "$0")/targeting.sh"
source "$(dirname "$0")/aws.sh"
source "$(dirname "$0")/cache.sh"
source "$(dirname "$0")/volume.sh"
source "$(dirname "$0")/shutdown.sh"
source "$(dirname "$0")/verify.sh"
source "$(dirname "$0")/status.sh"
source "$(dirname "$0")/display.sh"
source "$(dirname "$0")/args.sh"
source "$(dirname "$0")/operations.sh"

# Initialize shared utilities
init_shared_utilities

# ─────────────────────────────────────────────────────────────────────────────
# Main Entry Point
# ─────────────────────────────────────────────────────────────────────────────

# Main function - entry point for all operations
# Usage: main "$@"
main() {
    # Check for general help flag early
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        show_usage
        exit 0
    fi
    
    # Check for action-specific help (e.g., ./infra apply --help)
    if [[ $# -ge 2 && ("${2}" == "--help" || "${2}" == "-h") ]]; then
        show_action_help "${1}"
        exit 0
    fi
    
    # Set QUIET_MODE=1 for query action to suppress banners/logs
    if [[ "${1:-}" == "query" ]]; then
        export QUIET_MODE=1
    else
        export QUIET_MODE=0
    fi
    
    # Parse command-line arguments
    parse_arguments "$@"
    
    # Set up global variables from parsed arguments
    setup_global_environment
    
    # Initialize logging for the operation
    setup_operation_logging
    
    # Show operation summary
    show_operation_summary
    
    # Execute the requested operation
    execute_operation
    
    # Finalize and cleanup (suppress for query)
    if [[ "${QUIET_MODE:-0}" -ne 1 ]]; then
        finalize_operation
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Error Handling
# ─────────────────────────────────────────────────────────────────────────────

# Set up error trap
trap 'handle_operation_error "Operation failed with unexpected error"' ERR

# ─────────────────────────────────────────────────────────────────────────────
# Script Execution
# ─────────────────────────────────────────────────────────────────────────────

# Execute main function if script is run directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi 